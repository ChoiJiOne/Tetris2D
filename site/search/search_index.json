{"config":{"indexing":"full","lang":["en"],"min_search_length":3,"prebuild_index":false,"separator":"[\\s\\-]+"},"docs":[{"location":"","text":"Tetris2D C++\uacfc SDL2\ub97c \ud65c\uc6a9\ud55c 2D \ud14c\ud2b8\ub9ac\uc2a4 \uac8c\uc784 \uad6c\ud604 \ud504\ub85c\uc81d\ud2b8\uc758 Github Page \uc785\ub2c8\ub2e4. Document Tetris2D Github Page\ub294 \ub2e4\uc74c\uacfc \uac19\uc740 \ubb38\uc11c\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \ud504\ub85c\uc81d\ud2b8\uc758 \ubaa9\ud45c Visual Studio \uc194\ub8e8\uc158 \uc0dd\uc131 Tetris2D \uc870\uc5d8 \ud14c\uc2a4\ud2b8 \uac8c\uc784 \ub808\uc774\uc544\uc6c3 \ub514\uc790\uc778 \uacc4\ud68d","title":"Tetris2D"},{"location":"#tetris2d","text":"C++\uacfc SDL2\ub97c \ud65c\uc6a9\ud55c 2D \ud14c\ud2b8\ub9ac\uc2a4 \uac8c\uc784 \uad6c\ud604 \ud504\ub85c\uc81d\ud2b8\uc758 Github Page \uc785\ub2c8\ub2e4.","title":"Tetris2D"},{"location":"#document","text":"Tetris2D Github Page\ub294 \ub2e4\uc74c\uacfc \uac19\uc740 \ubb38\uc11c\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \ud504\ub85c\uc81d\ud2b8\uc758 \ubaa9\ud45c Visual Studio \uc194\ub8e8\uc158 \uc0dd\uc131 Tetris2D \uc870\uc5d8 \ud14c\uc2a4\ud2b8 \uac8c\uc784 \ub808\uc774\uc544\uc6c3 \ub514\uc790\uc778 \uacc4\ud68d","title":"Document"},{"location":"0001/","text":"\ud504\ub85c\uc81d\ud2b8 \ubaa9\ud45c \uc791\uc131\uc790 : \ucd5c\uc9c0\uc6d0 \ud504\ub85c\uc81d\ud2b8 \ubaa9\ud45c Tetris2D\uc758 \ubaa9\ud45c\ub294 \ub2e4\uc74c\uacfc \uac19\uc2b5\ub2c8\ub2e4. \uc2f1\uae00 \ud50c\ub808\uc774 \uac00\ub2a5\ud55c 2D \ud14c\ud2b8\ub9ac\uc2a4 \uac8c\uc784 \uad6c\ud604 \ub2e4\ub978 2D \uac8c\uc784 \uc81c\uc791\uc5d0\ub3c4 \ud65c\uc6a9\ud560 \uc218 \uc788\ub294 \uac8c\uc784 \uc5d4\uc9c4 \uad6c\ud604 Visual Studio \uc194\ub8e8\uc158 \uc0dd\uc131 \uc790\ub3d9\ud654 \uad6c\ud604 \uc870\uc5d8 \ud14c\uc2a4\ud2b8 8\uc810 \uc774\uc0c1 \ubc1b\uae30 \ucc38\uace0 : The Joel Test","title":"\ud504\ub85c\uc81d\ud2b8 \ubaa9\ud45c"},{"location":"0001/#_1","text":"\uc791\uc131\uc790 : \ucd5c\uc9c0\uc6d0","title":"\ud504\ub85c\uc81d\ud2b8 \ubaa9\ud45c"},{"location":"0001/#_2","text":"Tetris2D\uc758 \ubaa9\ud45c\ub294 \ub2e4\uc74c\uacfc \uac19\uc2b5\ub2c8\ub2e4. \uc2f1\uae00 \ud50c\ub808\uc774 \uac00\ub2a5\ud55c 2D \ud14c\ud2b8\ub9ac\uc2a4 \uac8c\uc784 \uad6c\ud604 \ub2e4\ub978 2D \uac8c\uc784 \uc81c\uc791\uc5d0\ub3c4 \ud65c\uc6a9\ud560 \uc218 \uc788\ub294 \uac8c\uc784 \uc5d4\uc9c4 \uad6c\ud604 Visual Studio \uc194\ub8e8\uc158 \uc0dd\uc131 \uc790\ub3d9\ud654 \uad6c\ud604 \uc870\uc5d8 \ud14c\uc2a4\ud2b8 8\uc810 \uc774\uc0c1 \ubc1b\uae30 \ucc38\uace0 : The Joel Test","title":"\ud504\ub85c\uc81d\ud2b8 \ubaa9\ud45c"},{"location":"0002/","text":"Visual Studio \uc194\ub8e8\uc158 \uc0dd\uc131 \uc790\ub3d9\ud654 \uc791\uc131\uc790 : \ucd5c\uc9c0\uc6d0 Visual Studio \uc194\ub8e8\uc158 \uc0dd\uc131 \uc790\ub3d9\ud654\ub97c \ud558\ub294 \uc774\uc720\ub294 \ubb34\uc5c7\uc778\uac00\uc694? Tetris2D \ud504\ub85c\uc81d\ud2b8\uc758 Visual Studio \uc194\ub8e8\uc158 \uc0dd\uc131\uc744 \uc790\ub3d9\ud654 \ud558\ub294 \uc774\uc720\ub294 \ud06c\uac8c \ub2e4\uc74c \ub450 \uac00\uc9c0 \ub54c\ubb38\uc785\ub2c8\ub2e4. \ub2e4\uc591\ud55c \ud658\uacbd\uc5d0\uc11c\uc758 \uad6c\ud604 \uc791\uc5c5 \uc9c4\ud589 \ube4c\ub4dc \uc790\ub3d9\ud654 \uc791\uc5c5 \uccab \ubc88\uc9f8\uc758 \uacbd\uc6b0, \uc9d1\uc5d0\uc11c \uc791\uc5c5\ud560 \ub54c\uac00 \ub300\ubd80\ubd84\uc774\uc9c0\ub9cc \ud2b9\ubcc4\ud55c \uacbd\uc6b0\uc5d0 \ubc16\uc5d0\uc11c \ub178\ud2b8\ubd81\uc73c\ub85c \uc791\uc5c5\ud558\ub294 \uacbd\uc6b0\uac00 \uc788\ub294\ub370, \ucc98\uc74c\uc5d0 \uc0dd\uc131\ud55c \uc194\ub8e8\uc158\uc744 \uadf8\ub300\ub85c \uc0ac\uc6a9\ud560 \uacbd\uc6b0 Windows SDK\uc758 \ubc84\uc804\uc774 \ub2e4\ub974\uba74 \ube4c\ub4dc\uac00 \ub418\uc9c0 \uc54a\ub294 \uacbd\uc6b0\uac00 \uc788\uc2b5\ub2c8\ub2e4. \ub530\ub77c\uc11c, \uc774\ub7ec\ud55c \uc0c1\ud669\uc744 \ubbf8\ub9ac \ub9c9\uae30 \uc704\ud574 Visual Studio \uc194\ub8e8\uc158 \uc0dd\uc131 \uc790\ub3d9\ud654\ub97c \uad6c\ud604\ud569\ub2c8\ub2e4. \ub450 \ubc88\uc9f8\uc758 \uacbd\uc6b0, \uc870\uc5d8 \ud14c\uc2a4\ud2b8 \ud56d\ubaa9\uc5d0\ub3c4 \uc788\ub4ef\uc774 \uc774\ub294 \uc77c\uc77c \ube4c\ub4dc\ub97c \uc790\ub3d9\ud654 \ud558\uae30 \uc704\ud55c \uac83\uc73c\ub85c \uc790\ub3d9\uc73c\ub85c Visual Studio \uc194\ub8e8\uc158\uc744 \uc0dd\uc131\ud55c \ub4a4\uc5d0 \uadf8 \uc194\ub8e8\uc158\uacfc MSBuild.exe \ub97c \uc0ac\uc6a9\ud558\uc5ec \uc77c\uc77c \ube4c\ub4dc \uc790\ub3d9\ud654\ub97c \uad6c\ud604\ud558\uae30 \uc704\ud568\uc785\ub2c8\ub2e4. Visual Studio \uc194\ub8e8\uc158 \uc0dd\uc131 \uc790\ub3d9\ud654 \uad6c\ud604\uc740 \ubb34\uc5c7\uc744 \uc774\uc6a9\ud574\uc11c \ud558\ub098\uc694? Visual Studio \uc194\ub8e8\uc158 \uc0dd\uc131 \uc790\ub3d9\ud654\uc758 \uacbd\uc6b0 \ub9ce\uc740 \uc624\ud508 \uc18c\uc2a4 \ud504\ub85c\uc81d\ud2b8\uac00 CMake \ub97c \uc0ac\uc6a9\ud569\ub2c8\ub2e4. \ud558\uc9c0\ub9cc, \uc774 \ud504\ub85c\uc81d\ud2b8\uc758 \uacbd\uc6b0 \ub2e8 \ud558\ub098\uc774\uc9c0\ub9cc \ubb34\uc870\uac74\uc801\uc774\uace0 \uac15\ub825\ud55c \uc870\uac74\uc744 \ub9cc\uc871\ud574\uc57c \ud569\ub2c8\ub2e4. \uadf8\uac83\uc740 \"\uc27d\uace0 \uac04\ub2e8\ud558\uac8c \uc0ac\uc6a9\ud560 \uc218 \uc788\uc5b4\uc57c \ud55c\ub2e4.\" \uc785\ub2c8\ub2e4. \uc774 \uc870\uac74\uc744 \ub9cc\uc871\ud558\ub294 \uac83\uc73c\ub85c\ub294 Premake \uac00 \uc788\uc2b5\ub2c8\ub2e4. \ub530\ub77c\uc11c, \uc774 Tetris2D \ud504\ub85c\uc81d\ud2b8\uc5d0\uc11c Visual Studio \uc194\ub8e8\uc158 \uc0dd\uc131 \uc790\ub3d9\ud654\ub97c \uc218\ud589\ud558\uae30 \uc704\ud574\uc11c\ub294 Premake5\ub97c \uc0ac\uc6a9\ud569\ub2c8\ub2e4. Visual Studio \uc194\ub8e8\uc158 \uc0dd\uc131\uc744 \uc0dd\uc131\ud558\ub294 \ubc29\ubc95 \ud504\ub85c\uc81d\ud2b8 \ub0b4\uc5d0 GenerateProjectFiles.bat \ud30c\uc77c\uc744 \uc2e4\ud589\ud560 \uacbd\uc6b0, Tetris2D \ud3f4\ub354 \ud558\uc704\uc5d0 Tetris2D.sln \ud30c\uc77c\uc744 \uc5bb\uc744 \uc218 \uc788\uc2b5\ub2c8\ub2e4.","title":"Visual Studio \uc194\ub8e8\uc158 \uc0dd\uc131 \uc790\ub3d9\ud654"},{"location":"0002/#visual-studio","text":"\uc791\uc131\uc790 : \ucd5c\uc9c0\uc6d0","title":"Visual Studio \uc194\ub8e8\uc158 \uc0dd\uc131 \uc790\ub3d9\ud654"},{"location":"0002/#visual-studio_1","text":"Tetris2D \ud504\ub85c\uc81d\ud2b8\uc758 Visual Studio \uc194\ub8e8\uc158 \uc0dd\uc131\uc744 \uc790\ub3d9\ud654 \ud558\ub294 \uc774\uc720\ub294 \ud06c\uac8c \ub2e4\uc74c \ub450 \uac00\uc9c0 \ub54c\ubb38\uc785\ub2c8\ub2e4. \ub2e4\uc591\ud55c \ud658\uacbd\uc5d0\uc11c\uc758 \uad6c\ud604 \uc791\uc5c5 \uc9c4\ud589 \ube4c\ub4dc \uc790\ub3d9\ud654 \uc791\uc5c5 \uccab \ubc88\uc9f8\uc758 \uacbd\uc6b0, \uc9d1\uc5d0\uc11c \uc791\uc5c5\ud560 \ub54c\uac00 \ub300\ubd80\ubd84\uc774\uc9c0\ub9cc \ud2b9\ubcc4\ud55c \uacbd\uc6b0\uc5d0 \ubc16\uc5d0\uc11c \ub178\ud2b8\ubd81\uc73c\ub85c \uc791\uc5c5\ud558\ub294 \uacbd\uc6b0\uac00 \uc788\ub294\ub370, \ucc98\uc74c\uc5d0 \uc0dd\uc131\ud55c \uc194\ub8e8\uc158\uc744 \uadf8\ub300\ub85c \uc0ac\uc6a9\ud560 \uacbd\uc6b0 Windows SDK\uc758 \ubc84\uc804\uc774 \ub2e4\ub974\uba74 \ube4c\ub4dc\uac00 \ub418\uc9c0 \uc54a\ub294 \uacbd\uc6b0\uac00 \uc788\uc2b5\ub2c8\ub2e4. \ub530\ub77c\uc11c, \uc774\ub7ec\ud55c \uc0c1\ud669\uc744 \ubbf8\ub9ac \ub9c9\uae30 \uc704\ud574 Visual Studio \uc194\ub8e8\uc158 \uc0dd\uc131 \uc790\ub3d9\ud654\ub97c \uad6c\ud604\ud569\ub2c8\ub2e4. \ub450 \ubc88\uc9f8\uc758 \uacbd\uc6b0, \uc870\uc5d8 \ud14c\uc2a4\ud2b8 \ud56d\ubaa9\uc5d0\ub3c4 \uc788\ub4ef\uc774 \uc774\ub294 \uc77c\uc77c \ube4c\ub4dc\ub97c \uc790\ub3d9\ud654 \ud558\uae30 \uc704\ud55c \uac83\uc73c\ub85c \uc790\ub3d9\uc73c\ub85c Visual Studio \uc194\ub8e8\uc158\uc744 \uc0dd\uc131\ud55c \ub4a4\uc5d0 \uadf8 \uc194\ub8e8\uc158\uacfc MSBuild.exe \ub97c \uc0ac\uc6a9\ud558\uc5ec \uc77c\uc77c \ube4c\ub4dc \uc790\ub3d9\ud654\ub97c \uad6c\ud604\ud558\uae30 \uc704\ud568\uc785\ub2c8\ub2e4.","title":"Visual Studio \uc194\ub8e8\uc158 \uc0dd\uc131 \uc790\ub3d9\ud654\ub97c \ud558\ub294 \uc774\uc720\ub294 \ubb34\uc5c7\uc778\uac00\uc694?"},{"location":"0002/#visual-studio_2","text":"Visual Studio \uc194\ub8e8\uc158 \uc0dd\uc131 \uc790\ub3d9\ud654\uc758 \uacbd\uc6b0 \ub9ce\uc740 \uc624\ud508 \uc18c\uc2a4 \ud504\ub85c\uc81d\ud2b8\uac00 CMake \ub97c \uc0ac\uc6a9\ud569\ub2c8\ub2e4. \ud558\uc9c0\ub9cc, \uc774 \ud504\ub85c\uc81d\ud2b8\uc758 \uacbd\uc6b0 \ub2e8 \ud558\ub098\uc774\uc9c0\ub9cc \ubb34\uc870\uac74\uc801\uc774\uace0 \uac15\ub825\ud55c \uc870\uac74\uc744 \ub9cc\uc871\ud574\uc57c \ud569\ub2c8\ub2e4. \uadf8\uac83\uc740 \"\uc27d\uace0 \uac04\ub2e8\ud558\uac8c \uc0ac\uc6a9\ud560 \uc218 \uc788\uc5b4\uc57c \ud55c\ub2e4.\" \uc785\ub2c8\ub2e4. \uc774 \uc870\uac74\uc744 \ub9cc\uc871\ud558\ub294 \uac83\uc73c\ub85c\ub294 Premake \uac00 \uc788\uc2b5\ub2c8\ub2e4. \ub530\ub77c\uc11c, \uc774 Tetris2D \ud504\ub85c\uc81d\ud2b8\uc5d0\uc11c Visual Studio \uc194\ub8e8\uc158 \uc0dd\uc131 \uc790\ub3d9\ud654\ub97c \uc218\ud589\ud558\uae30 \uc704\ud574\uc11c\ub294 Premake5\ub97c \uc0ac\uc6a9\ud569\ub2c8\ub2e4.","title":"Visual Studio \uc194\ub8e8\uc158 \uc0dd\uc131 \uc790\ub3d9\ud654 \uad6c\ud604\uc740 \ubb34\uc5c7\uc744 \uc774\uc6a9\ud574\uc11c \ud558\ub098\uc694?"},{"location":"0002/#visual-studio_3","text":"\ud504\ub85c\uc81d\ud2b8 \ub0b4\uc5d0 GenerateProjectFiles.bat \ud30c\uc77c\uc744 \uc2e4\ud589\ud560 \uacbd\uc6b0, Tetris2D \ud3f4\ub354 \ud558\uc704\uc5d0 Tetris2D.sln \ud30c\uc77c\uc744 \uc5bb\uc744 \uc218 \uc788\uc2b5\ub2c8\ub2e4.","title":"Visual Studio \uc194\ub8e8\uc158 \uc0dd\uc131\uc744 \uc0dd\uc131\ud558\ub294 \ubc29\ubc95"},{"location":"0003/","text":"\uc870\uc5d8 \ud14c\uc2a4\ud2b8 \uc791\uc131\uc790 : \ucd5c\uc9c0\uc6d0 \uc870\uc5d8 \ud14c\uc2a4\ud2b8\ub97c \ud574\uc57c \ud558\ub294 \uc774\uc720\ub294 \ubb34\uc5c7\uc778\uac00\uc694? \uc870\uc5d8 \ud14c\uc2a4\ud2b8\ub97c \ud1b5\ud574 \ud604\uc7ac \uc9c4\ud589 \uc911\uc778 \uc18c\ud504\ud2b8\uc6e8\uc5b4 \ud504\ub85c\uc81d\ud2b8\ub97c \ud3c9\uac00\ud558\uace0, \ubd80\uc871\ud55c \ubd80\ubd84\uc740 \uac1c\uc120\uc744 \ud558\uba74\uc11c \ucd5c\uc885\uc801\uc73c\ub85c \ud504\ub85c\uc81d\ud2b8\ub97c \uc885\ub8cc\ud588\uc744 \ub54c \ubaa9\ud45c\uc5d0\uc11c \uc5b8\uae09\ud55c 8\uc810 \uc774\uc0c1\uc744 \uc5bb\uae30 \uc704\ud568\uc785\ub2c8\ub2e4. \uc870\uc5d8 \ud14c\uc2a4\ud2b8 12\uac1c \ud56d\ubaa9 \ubc88\ud638 \ud56d\ubaa9 1. \uc18c\uc2a4\ucf54\ub4dc \uad00\ub9ac \uc2dc\uc2a4\ud15c\uc744 \uc0ac\uc6a9\ud558\uace0 \uc788\uc2b5\ub2c8\uae4c? 2. \ud55c\ubc29\uc5d0 \ube4c\ub4dc\ub97c \ub9cc\ub4e4\uc5b4\ub0bc \uc218 \uc788\uc2b5\ub2c8\uae4c? 3. \uc77c\uc77c \ube4c\ub4dc\ub97c \ud558\uace0 \uc788\uc2b5\ub2c8\uae4c? 4. \ubc84\uadf8 \ucd94\uc801\uc2dc\uc2a4\ud15c\uc744 \uc6b4\uc601\ud558\uace0 \uc788\uc2b5\ub2c8\uae4c? 5. \ucf54\ub4dc\ub97c \uc0c8\ub85c \uc791\uc131\ud558\uae30 \uc804\uc5d0 \ubc84\uadf8\ub97c \uc218\uc815\ud569\ub2c8\uae4c? 6. \uc77c\uc815\uc744 \uc5c5\ub370\uc774\ud2b8\ud558\uace0 \uc788\uc2b5\ub2c8\uae4c? 7. \uba85\uc138\uc11c\ub97c \uc791\uc131\ud558\uace0 \uc788\uc2b5\ub2c8\uae4c? 8. \uc870\uc6a9\ud55c \uc791\uc5c5 \ud658\uacbd\uc5d0\uc11c \uc77c\ud558\uace0 \uc788\uc2b5\ub2c8\uae4c? 9. \uacbd\uc81c\uc801\uc778 \ubc94\uc704 \ub0b4\uc5d0\uc11c \ucd5c\uace0 \uc131\ub2a5\uc758 \ub3c4\uad6c\ub97c \uc0ac\uc6a9\ud558\uace0 \uc788\uc2b5\ub2c8\uae4c? 10. \ud14c\uc2a4\ud130\ub97c \ubcc4\ub3c4\ub85c \ub450\uace0 \uc788\uc2b5\ub2c8\uae4c? 11. \ud504\ub85c\uadf8\ub798\uba38 \ucc44\uc6a9 \uc778\ud130\ubdf0 \ub54c \ucf54\ub529 \ud14c\uc2a4\ud2b8\ub97c \ud569\ub2c8\uae4c? 12. \ubb34\uc791\uc704 \uc0ac\uc6a9\ud3b8\uc758\uc131 \ud14c\uc2a4\ud2b8(\ubc29\uae08 \ub9c9 \uc791\uc131\ud55c \ucf54\ub4dc\ub97c \ub2e4\ub978 \uc0ac\ub78c\uc5d0\uac8c \uc0ac\uc6a9\ud574\ubcf4\ub3c4\ub85d \ud558\ub294 \uae30\ubc95)\ub97c \ucd94\uac00\ud558\uace0 \uc788\uc2b5\ub2c8\uae4c? Reference \uc870\uc5d8 \uc628 \uc18c\ud504\ud2b8\uc6e8\uc5b4 : \uc870\uc5d8 \ud14c\uc2a4\ud2b8, \ub354 \ub098\uc740 \ucf54\ub4dc\ub97c \uc704\ud55c 12\ub2e8\uacc4","title":"\uc870\uc5d8 \ud14c\uc2a4\ud2b8"},{"location":"0003/#_1","text":"\uc791\uc131\uc790 : \ucd5c\uc9c0\uc6d0","title":"\uc870\uc5d8 \ud14c\uc2a4\ud2b8"},{"location":"0003/#_2","text":"\uc870\uc5d8 \ud14c\uc2a4\ud2b8\ub97c \ud1b5\ud574 \ud604\uc7ac \uc9c4\ud589 \uc911\uc778 \uc18c\ud504\ud2b8\uc6e8\uc5b4 \ud504\ub85c\uc81d\ud2b8\ub97c \ud3c9\uac00\ud558\uace0, \ubd80\uc871\ud55c \ubd80\ubd84\uc740 \uac1c\uc120\uc744 \ud558\uba74\uc11c \ucd5c\uc885\uc801\uc73c\ub85c \ud504\ub85c\uc81d\ud2b8\ub97c \uc885\ub8cc\ud588\uc744 \ub54c \ubaa9\ud45c\uc5d0\uc11c \uc5b8\uae09\ud55c 8\uc810 \uc774\uc0c1\uc744 \uc5bb\uae30 \uc704\ud568\uc785\ub2c8\ub2e4.","title":"\uc870\uc5d8 \ud14c\uc2a4\ud2b8\ub97c \ud574\uc57c \ud558\ub294 \uc774\uc720\ub294 \ubb34\uc5c7\uc778\uac00\uc694?"},{"location":"0003/#12","text":"\ubc88\ud638 \ud56d\ubaa9 1. \uc18c\uc2a4\ucf54\ub4dc \uad00\ub9ac \uc2dc\uc2a4\ud15c\uc744 \uc0ac\uc6a9\ud558\uace0 \uc788\uc2b5\ub2c8\uae4c? 2. \ud55c\ubc29\uc5d0 \ube4c\ub4dc\ub97c \ub9cc\ub4e4\uc5b4\ub0bc \uc218 \uc788\uc2b5\ub2c8\uae4c? 3. \uc77c\uc77c \ube4c\ub4dc\ub97c \ud558\uace0 \uc788\uc2b5\ub2c8\uae4c? 4. \ubc84\uadf8 \ucd94\uc801\uc2dc\uc2a4\ud15c\uc744 \uc6b4\uc601\ud558\uace0 \uc788\uc2b5\ub2c8\uae4c? 5. \ucf54\ub4dc\ub97c \uc0c8\ub85c \uc791\uc131\ud558\uae30 \uc804\uc5d0 \ubc84\uadf8\ub97c \uc218\uc815\ud569\ub2c8\uae4c? 6. \uc77c\uc815\uc744 \uc5c5\ub370\uc774\ud2b8\ud558\uace0 \uc788\uc2b5\ub2c8\uae4c? 7. \uba85\uc138\uc11c\ub97c \uc791\uc131\ud558\uace0 \uc788\uc2b5\ub2c8\uae4c? 8. \uc870\uc6a9\ud55c \uc791\uc5c5 \ud658\uacbd\uc5d0\uc11c \uc77c\ud558\uace0 \uc788\uc2b5\ub2c8\uae4c? 9. \uacbd\uc81c\uc801\uc778 \ubc94\uc704 \ub0b4\uc5d0\uc11c \ucd5c\uace0 \uc131\ub2a5\uc758 \ub3c4\uad6c\ub97c \uc0ac\uc6a9\ud558\uace0 \uc788\uc2b5\ub2c8\uae4c? 10. \ud14c\uc2a4\ud130\ub97c \ubcc4\ub3c4\ub85c \ub450\uace0 \uc788\uc2b5\ub2c8\uae4c? 11. \ud504\ub85c\uadf8\ub798\uba38 \ucc44\uc6a9 \uc778\ud130\ubdf0 \ub54c \ucf54\ub529 \ud14c\uc2a4\ud2b8\ub97c \ud569\ub2c8\uae4c? 12. \ubb34\uc791\uc704 \uc0ac\uc6a9\ud3b8\uc758\uc131 \ud14c\uc2a4\ud2b8(\ubc29\uae08 \ub9c9 \uc791\uc131\ud55c \ucf54\ub4dc\ub97c \ub2e4\ub978 \uc0ac\ub78c\uc5d0\uac8c \uc0ac\uc6a9\ud574\ubcf4\ub3c4\ub85d \ud558\ub294 \uae30\ubc95)\ub97c \ucd94\uac00\ud558\uace0 \uc788\uc2b5\ub2c8\uae4c?","title":"\uc870\uc5d8 \ud14c\uc2a4\ud2b8 12\uac1c \ud56d\ubaa9"},{"location":"0003/#reference","text":"\uc870\uc5d8 \uc628 \uc18c\ud504\ud2b8\uc6e8\uc5b4 : \uc870\uc5d8 \ud14c\uc2a4\ud2b8, \ub354 \ub098\uc740 \ucf54\ub4dc\ub97c \uc704\ud55c 12\ub2e8\uacc4","title":"Reference"},{"location":"0004/","text":"\uac8c\uc784 \ub808\uc774\uc544\uc6c3 \ub514\uc790\uc778 \uacc4\ud68d \uc791\uc131\uc790 : \ucd5c\uc9c0\uc6d0 \uac8c\uc784 \ub808\uc774\uc544\uc6c3 \ub514\uc790\uc778 \uacc4\ud68d \uac8c\uc784 \ub808\uc774\uc544\uc6c3 \ub514\uc790\uc778\uc740 \uc544\ub798\uc758 \uc774\ubbf8\uc9c0\uc640 \uac19\uc774 \ud558\uae30\ub85c \uc815\ud588\uc2b5\ub2c8\ub2e4. \uadf8\ub9bc\ud310\uc744 \uc774\uc6a9\ud574\uc11c \uadf8\ub9bc\uc774 \uc774\uc0c1\ud569\ub2c8\ub2e4. \uac8c\uc784 \ub808\uc774\uc544\uc6c3 \ub514\uc790\uc778 \uc124\uba85 \uc67c\ucabd\uc758 \ud14c\ud2b8\ub85c\ubbf8\ub178\uac00 \uc788\ub294 \uc601\uc5ed\uc740 \uac8c\uc784 \ud50c\ub808\uc774\uc601\uc5ed \uc785\ub2c8\ub2e4. Next\uac00 \uc788\ub294 \uc601\uc5ed\uc740 \ub2e4\uc74c\uc5d0 \uac8c\uc784 \ud50c\ub808\uc774\uc601\uc5ed\uc5d0 \ubc30\uce58\ub420 \ud14c\ud2b8\ub85c\ubbf8\ub178\ub97c \ubcf4\uc5ec\uc90d\ub2c8\ub2e4. Time\uc774 \uc788\ub294 \uc601\uc5ed\uc740 \ud604\uc7ac \ub808\ubca8\uc758 \ub0a8\uc740 \uc2dc\uac04\uc744 \ubcf4\uc5ec\uc90d\ub2c8\ub2e4. Level\uc774 \uc788\ub294 \uc601\uc5ed\uc740 \ud604\uc7ac \ud50c\ub808\uc774\uc5b4\uc758 \ub808\ubca8\ub97c \ubcf4\uc5ec\uc90d\ub2c8\ub2e4. Line\uc774 \uc788\ub294 \uc601\uc5ed\uc740 \uac8c\uc784 \ud50c\ub808\uc774\uc911 \uc0ad\uc81c\ud55c \ub77c\uc778 \uc218\ub97c \ubcf4\uc5ec\uc90d\ub2c8\ub2e4. Note \uc774\ub54c, \uc708\ub3c4\uc6b0\uc758 \ud06c\uae30\ub294 \ubcc0\ud558\uc9c0 \uc54a\ub3c4\ub85d \uad6c\ud604\ud569\ub2c8\ub2e4. \ub514\uc790\uc778 \uadf8\ub9bc\uc5d0\ub294 \ud14c\ud2b8\ub85c\ubbf8\ub178\uc758 \uc0c9\uc0c1\uc774 \ub2e8\uc21c \uc6d0\uc0c9\uc73c\ub85c \ud45c\ud604\ub418\uc5b4 \uc788\uc9c0\ub9cc, \uc2e4\uc81c \uac8c\uc784\uc5d0\uc11c\ub294 \ubbf8\ub9ac \uc900\ube44\ud55c \ud14d\uc2a4\ucc98\ub97c \ud65c\uc6a9\ud569\ub2c8\ub2e4.","title":"\uac8c\uc784 \ub808\uc774\uc544\uc6c3 \ub514\uc790\uc778 \uacc4\ud68d"},{"location":"0004/#_1","text":"\uc791\uc131\uc790 : \ucd5c\uc9c0\uc6d0","title":"\uac8c\uc784 \ub808\uc774\uc544\uc6c3 \ub514\uc790\uc778 \uacc4\ud68d"},{"location":"0004/#_2","text":"\uac8c\uc784 \ub808\uc774\uc544\uc6c3 \ub514\uc790\uc778\uc740 \uc544\ub798\uc758 \uc774\ubbf8\uc9c0\uc640 \uac19\uc774 \ud558\uae30\ub85c \uc815\ud588\uc2b5\ub2c8\ub2e4. \uadf8\ub9bc\ud310\uc744 \uc774\uc6a9\ud574\uc11c \uadf8\ub9bc\uc774 \uc774\uc0c1\ud569\ub2c8\ub2e4.","title":"\uac8c\uc784 \ub808\uc774\uc544\uc6c3 \ub514\uc790\uc778 \uacc4\ud68d"},{"location":"0004/#_3","text":"\uc67c\ucabd\uc758 \ud14c\ud2b8\ub85c\ubbf8\ub178\uac00 \uc788\ub294 \uc601\uc5ed\uc740 \uac8c\uc784 \ud50c\ub808\uc774\uc601\uc5ed \uc785\ub2c8\ub2e4. Next\uac00 \uc788\ub294 \uc601\uc5ed\uc740 \ub2e4\uc74c\uc5d0 \uac8c\uc784 \ud50c\ub808\uc774\uc601\uc5ed\uc5d0 \ubc30\uce58\ub420 \ud14c\ud2b8\ub85c\ubbf8\ub178\ub97c \ubcf4\uc5ec\uc90d\ub2c8\ub2e4. Time\uc774 \uc788\ub294 \uc601\uc5ed\uc740 \ud604\uc7ac \ub808\ubca8\uc758 \ub0a8\uc740 \uc2dc\uac04\uc744 \ubcf4\uc5ec\uc90d\ub2c8\ub2e4. Level\uc774 \uc788\ub294 \uc601\uc5ed\uc740 \ud604\uc7ac \ud50c\ub808\uc774\uc5b4\uc758 \ub808\ubca8\ub97c \ubcf4\uc5ec\uc90d\ub2c8\ub2e4. Line\uc774 \uc788\ub294 \uc601\uc5ed\uc740 \uac8c\uc784 \ud50c\ub808\uc774\uc911 \uc0ad\uc81c\ud55c \ub77c\uc778 \uc218\ub97c \ubcf4\uc5ec\uc90d\ub2c8\ub2e4.","title":"\uac8c\uc784 \ub808\uc774\uc544\uc6c3 \ub514\uc790\uc778 \uc124\uba85"},{"location":"0004/#note","text":"\uc774\ub54c, \uc708\ub3c4\uc6b0\uc758 \ud06c\uae30\ub294 \ubcc0\ud558\uc9c0 \uc54a\ub3c4\ub85d \uad6c\ud604\ud569\ub2c8\ub2e4. \ub514\uc790\uc778 \uadf8\ub9bc\uc5d0\ub294 \ud14c\ud2b8\ub85c\ubbf8\ub178\uc758 \uc0c9\uc0c1\uc774 \ub2e8\uc21c \uc6d0\uc0c9\uc73c\ub85c \ud45c\ud604\ub418\uc5b4 \uc788\uc9c0\ub9cc, \uc2e4\uc81c \uac8c\uc784\uc5d0\uc11c\ub294 \ubbf8\ub9ac \uc900\ube44\ud55c \ud14d\uc2a4\ucc98\ub97c \ud65c\uc6a9\ud569\ub2c8\ub2e4.","title":"Note"}]}