{"config":{"indexing":"full","lang":["en"],"min_search_length":3,"prebuild_index":false,"separator":"[\\s\\-]+"},"docs":[{"location":"","text":"Tetris2D C++\uacfc SDL2\ub97c \ud65c\uc6a9\ud55c 2D \ud14c\ud2b8\ub9ac\uc2a4 \uac8c\uc784 \uad6c\ud604 \ud504\ub85c\uc81d\ud2b8\uc758 Github Page \uc785\ub2c8\ub2e4. Document Tetris2D Github Page\ub294 \ub2e4\uc74c\uacfc \uac19\uc740 \ubb38\uc11c\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \ud504\ub85c\uc81d\ud2b8\uc758 \ubaa9\ud45c Visual Studio \uc194\ub8e8\uc158 \uc0dd\uc131 Tetris2D \uc870\uc5d8 \ud14c\uc2a4\ud2b8","title":"Tetris2D"},{"location":"#tetris2d","text":"C++\uacfc SDL2\ub97c \ud65c\uc6a9\ud55c 2D \ud14c\ud2b8\ub9ac\uc2a4 \uac8c\uc784 \uad6c\ud604 \ud504\ub85c\uc81d\ud2b8\uc758 Github Page \uc785\ub2c8\ub2e4.","title":"Tetris2D"},{"location":"#document","text":"Tetris2D Github Page\ub294 \ub2e4\uc74c\uacfc \uac19\uc740 \ubb38\uc11c\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \ud504\ub85c\uc81d\ud2b8\uc758 \ubaa9\ud45c Visual Studio \uc194\ub8e8\uc158 \uc0dd\uc131 Tetris2D \uc870\uc5d8 \ud14c\uc2a4\ud2b8","title":"Document"},{"location":"0001/","text":"\ud504\ub85c\uc81d\ud2b8 \ubaa9\ud45c \uc791\uc131\uc790 : \ucd5c\uc9c0\uc6d0 \ud504\ub85c\uc81d\ud2b8 \ubaa9\ud45c Tetris2D\uc758 \ubaa9\ud45c\ub294 \ub2e4\uc74c\uacfc \uac19\uc2b5\ub2c8\ub2e4. \uc2f1\uae00 \ud50c\ub808\uc774 \uac00\ub2a5\ud55c 2D \ud14c\ud2b8\ub9ac\uc2a4 \uac8c\uc784 \uad6c\ud604 \ub2e4\ub978 2D \uac8c\uc784 \uc81c\uc791\uc5d0\ub3c4 \ud65c\uc6a9\ud560 \uc218 \uc788\ub294 \uac8c\uc784 \uc5d4\uc9c4 \uad6c\ud604 Visual Studio \uc194\ub8e8\uc158 \uc0dd\uc131 \uc790\ub3d9\ud654 \uad6c\ud604 \uc870\uc5d8 \ud14c\uc2a4\ud2b8 10\uc810 \uc774\uc0c1 \ubc1b\uae30 \ucc38\uace0 : The Joel Test","title":"\ud504\ub85c\uc81d\ud2b8 \ubaa9\ud45c"},{"location":"0001/#_1","text":"\uc791\uc131\uc790 : \ucd5c\uc9c0\uc6d0","title":"\ud504\ub85c\uc81d\ud2b8 \ubaa9\ud45c"},{"location":"0001/#_2","text":"Tetris2D\uc758 \ubaa9\ud45c\ub294 \ub2e4\uc74c\uacfc \uac19\uc2b5\ub2c8\ub2e4. \uc2f1\uae00 \ud50c\ub808\uc774 \uac00\ub2a5\ud55c 2D \ud14c\ud2b8\ub9ac\uc2a4 \uac8c\uc784 \uad6c\ud604 \ub2e4\ub978 2D \uac8c\uc784 \uc81c\uc791\uc5d0\ub3c4 \ud65c\uc6a9\ud560 \uc218 \uc788\ub294 \uac8c\uc784 \uc5d4\uc9c4 \uad6c\ud604 Visual Studio \uc194\ub8e8\uc158 \uc0dd\uc131 \uc790\ub3d9\ud654 \uad6c\ud604 \uc870\uc5d8 \ud14c\uc2a4\ud2b8 10\uc810 \uc774\uc0c1 \ubc1b\uae30 \ucc38\uace0 : The Joel Test","title":"\ud504\ub85c\uc81d\ud2b8 \ubaa9\ud45c"},{"location":"0002/","text":"Visual Studio \uc194\ub8e8\uc158 \uc0dd\uc131 \uc791\uc131\uc790 : \ucd5c\uc9c0\uc6d0 Visual Studio \uc194\ub8e8\uc158 \uc0dd\uc131 Tetris2D \ud504\ub85c\uc81d\ud2b8\ub294 \uad6c\ud604 \uc791\uc5c5, \ub514\ubc84\uae45, \ube4c\ub4dc\ub97c \uc704\ud55c \uc194\ub8e8\uc158 \uc0dd\uc131 \uc790\ub3d9\ud654\ub97c \uc9c0\uc6d0\ud569\ub2c8\ub2e4! \ud504\ub85c\uc81d\ud2b8 \ub0b4\uc5d0 GenerateProjectFiles.bat \ud30c\uc77c\uc744 \uc2e4\ud589\ud560 \uacbd\uc6b0, Tetris2D \ud3f4\ub354\uc640 Tetris2D.sln \ud30c\uc77c\uc744 \uc5bb\uc744 \uc218 \uc788\uc2b5\ub2c8\ub2e4.","title":"Visual Studio \uc194\ub8e8\uc158 \uc0dd\uc131"},{"location":"0002/#visual-studio","text":"\uc791\uc131\uc790 : \ucd5c\uc9c0\uc6d0","title":"Visual Studio \uc194\ub8e8\uc158 \uc0dd\uc131"},{"location":"0002/#visual-studio_1","text":"Tetris2D \ud504\ub85c\uc81d\ud2b8\ub294 \uad6c\ud604 \uc791\uc5c5, \ub514\ubc84\uae45, \ube4c\ub4dc\ub97c \uc704\ud55c \uc194\ub8e8\uc158 \uc0dd\uc131 \uc790\ub3d9\ud654\ub97c \uc9c0\uc6d0\ud569\ub2c8\ub2e4! \ud504\ub85c\uc81d\ud2b8 \ub0b4\uc5d0 GenerateProjectFiles.bat \ud30c\uc77c\uc744 \uc2e4\ud589\ud560 \uacbd\uc6b0, Tetris2D \ud3f4\ub354\uc640 Tetris2D.sln \ud30c\uc77c\uc744 \uc5bb\uc744 \uc218 \uc788\uc2b5\ub2c8\ub2e4.","title":"Visual Studio \uc194\ub8e8\uc158 \uc0dd\uc131"},{"location":"0003/","text":"Tetris2D \uc870\uc5d8 \ud14c\uc2a4\ud2b8 \uc791\uc131\uc790 : \ucd5c\uc9c0\uc6d0 \uc870\uc5d8 \ud14c\uc2a4\ud2b8 12\ub2e8\uacc4 \ud14c\uc2a4\ud2b8 Y/N \uc18c\uc2a4\ucf54\ub4dc \uad00\ub9ac \uc2dc\uc2a4\ud15c\uc744 \uc0ac\uc6a9\ud558\uace0 \uc788\uc2b5\ub2c8\uae4c? Y \ud55c\ubc29\uc5d0 \ube4c\ub4dc\ub97c \ub9cc\ub4e4\uc5b4\ub0bc \uc218 \uc788\uc2b5\ub2c8\uae4c? N \uc77c\uc77c \ube4c\ub4dc\ub97c \ud558\uace0 \uc788\uc2b5\ub2c8\uae4c? N \ubc84\uadf8 \ucd94\uc801\uc2dc\uc2a4\ud15c\uc744 \uc6b4\uc601\ud558\uace0 \uc788\uc2b5\ub2c8\uae4c? N \ucf54\ub4dc\ub97c \uc0c8\ub85c \uc791\uc131\ud558\uae30 \uc804\uc5d0 \ubc84\uadf8\ub97c \uc218\uc815\ud569\ub2c8\uae4c? N \uc77c\uc815\uc744 \uc5c5\ub370\uc774\ud2b8\ud558\uace0 \uc788\uc2b5\ub2c8\uae4c? N \uba85\uc138\uc11c\ub97c \uc791\uc131\ud558\uace0 \uc788\uc2b5\ub2c8\uae4c? N \uc870\uc6a9\ud55c \uc791\uc5c5 \ud658\uacbd\uc5d0\uc11c \uc77c\ud558\uace0 \uc788\uc2b5\ub2c8\uae4c? N \uacbd\uc81c\uc801\uc778 \ubc94\uc704 \ub0b4\uc5d0\uc11c \ucd5c\uace0 \uc131\ub2a5\uc758 \ub3c4\uad6c\ub97c \uc0ac\uc6a9\ud558\uace0 \uc788\uc2b5\ub2c8\uae4c? N \ud14c\uc2a4\ud130\ub97c \ubcc4\ub3c4\ub85c \ub450\uace0 \uc788\uc2b5\ub2c8\uae4c? N \ud504\ub85c\uadf8\ub798\uba38 \ucc44\uc6a9 \uc778\ud130\ubdf0 \ub54c \ucf54\ub529 \ud14c\uc2a4\ud2b8\ub97c \ud569\ub2c8\uae4c? N \ubb34\uc791\uc704 \uc0ac\uc6a9\ud3b8\uc758\uc131 \ud14c\uc2a4\ud2b8(\ubc29\uae08 \ub9c9 \uc791\uc131\ud55c \ucf54\ub4dc\ub97c \ub2e4\ub978 \uc0ac\ub78c\uc5d0\uac8c \uc0ac\uc6a9\ud574\ubcf4\ub3c4\ub85d \ud558\ub294 \uae30\ubc95)\ub97c \ucd94\uac00\ud558\uace0 \uc788\uc2b5\ub2c8\uae4c? N \uc18c\uc2a4\ucf54\ub4dc \uad00\ub9ac \uc2dc\uc2a4\ud15c\uc744 \uc0ac\uc6a9\ud558\uace0 \uc788\uc2b5\ub2c8\uae4c? \ub124. \ud604\uc7ac git\uc744 \uc774\uc6a9\ud558\uc5ec \uc18c\uc2a4\ucf54\ub4dc\ub97c \uad00\ub9ac\ud558\uace0 \uc788\uace0, github\ub77c\ub294 git \ud638\uc2a4\ud305 \uc11c\ube44\uc2a4\ub97c \uc774\uc6a9\ud574\uc11c \ud504\ub85c\uc81d\ud2b8\ub97c \uc624\ud508\uc18c\uc2a4\ud654 \ud558\uace0 \uc788\uc2b5\ub2c8\ub2e4.","title":"Tetris2D \uc870\uc5d8 \ud14c\uc2a4\ud2b8"},{"location":"0003/#tetris2d","text":"\uc791\uc131\uc790 : \ucd5c\uc9c0\uc6d0","title":"Tetris2D \uc870\uc5d8 \ud14c\uc2a4\ud2b8"},{"location":"0003/#12","text":"\ud14c\uc2a4\ud2b8 Y/N \uc18c\uc2a4\ucf54\ub4dc \uad00\ub9ac \uc2dc\uc2a4\ud15c\uc744 \uc0ac\uc6a9\ud558\uace0 \uc788\uc2b5\ub2c8\uae4c? Y \ud55c\ubc29\uc5d0 \ube4c\ub4dc\ub97c \ub9cc\ub4e4\uc5b4\ub0bc \uc218 \uc788\uc2b5\ub2c8\uae4c? N \uc77c\uc77c \ube4c\ub4dc\ub97c \ud558\uace0 \uc788\uc2b5\ub2c8\uae4c? N \ubc84\uadf8 \ucd94\uc801\uc2dc\uc2a4\ud15c\uc744 \uc6b4\uc601\ud558\uace0 \uc788\uc2b5\ub2c8\uae4c? N \ucf54\ub4dc\ub97c \uc0c8\ub85c \uc791\uc131\ud558\uae30 \uc804\uc5d0 \ubc84\uadf8\ub97c \uc218\uc815\ud569\ub2c8\uae4c? N \uc77c\uc815\uc744 \uc5c5\ub370\uc774\ud2b8\ud558\uace0 \uc788\uc2b5\ub2c8\uae4c? N \uba85\uc138\uc11c\ub97c \uc791\uc131\ud558\uace0 \uc788\uc2b5\ub2c8\uae4c? N \uc870\uc6a9\ud55c \uc791\uc5c5 \ud658\uacbd\uc5d0\uc11c \uc77c\ud558\uace0 \uc788\uc2b5\ub2c8\uae4c? N \uacbd\uc81c\uc801\uc778 \ubc94\uc704 \ub0b4\uc5d0\uc11c \ucd5c\uace0 \uc131\ub2a5\uc758 \ub3c4\uad6c\ub97c \uc0ac\uc6a9\ud558\uace0 \uc788\uc2b5\ub2c8\uae4c? N \ud14c\uc2a4\ud130\ub97c \ubcc4\ub3c4\ub85c \ub450\uace0 \uc788\uc2b5\ub2c8\uae4c? N \ud504\ub85c\uadf8\ub798\uba38 \ucc44\uc6a9 \uc778\ud130\ubdf0 \ub54c \ucf54\ub529 \ud14c\uc2a4\ud2b8\ub97c \ud569\ub2c8\uae4c? N \ubb34\uc791\uc704 \uc0ac\uc6a9\ud3b8\uc758\uc131 \ud14c\uc2a4\ud2b8(\ubc29\uae08 \ub9c9 \uc791\uc131\ud55c \ucf54\ub4dc\ub97c \ub2e4\ub978 \uc0ac\ub78c\uc5d0\uac8c \uc0ac\uc6a9\ud574\ubcf4\ub3c4\ub85d \ud558\ub294 \uae30\ubc95)\ub97c \ucd94\uac00\ud558\uace0 \uc788\uc2b5\ub2c8\uae4c? N","title":"\uc870\uc5d8 \ud14c\uc2a4\ud2b8 12\ub2e8\uacc4"},{"location":"0003/#_1","text":"\ub124. \ud604\uc7ac git\uc744 \uc774\uc6a9\ud558\uc5ec \uc18c\uc2a4\ucf54\ub4dc\ub97c \uad00\ub9ac\ud558\uace0 \uc788\uace0, github\ub77c\ub294 git \ud638\uc2a4\ud305 \uc11c\ube44\uc2a4\ub97c \uc774\uc6a9\ud574\uc11c \ud504\ub85c\uc81d\ud2b8\ub97c \uc624\ud508\uc18c\uc2a4\ud654 \ud558\uace0 \uc788\uc2b5\ub2c8\ub2e4.","title":"\uc18c\uc2a4\ucf54\ub4dc \uad00\ub9ac \uc2dc\uc2a4\ud15c\uc744 \uc0ac\uc6a9\ud558\uace0 \uc788\uc2b5\ub2c8\uae4c?"}]}